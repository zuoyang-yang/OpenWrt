# Target Config
CONFIG_TARGET_rockchip=y
CONFIG_TARGET_rockchip_armv8=y
CONFIG_TARGET_MULTI_PROFILE=y
CONFIG_TARGET_DEVICE_rockchip_armv8_DEVICE_fastrhino_r66s=y

# Firmware Size
CONFIG_TARGET_KERNEL_PARTSIZE=64
CONFIG_TARGET_ROOTFS_PARTSIZE=960
CONFIG_TARGET_ROOTFS_SQUASHFS=y
CONFIG_TARGET_ROOTFS_TARGZ=y

# ==========================
# 5G 通用驱动
# ==========================
CONFIG_PACKAGE_kmod-usb-net-qmi-wwan=y
CONFIG_PACKAGE_kmod-usb-net-cdc-ether=y
CONFIG_PACKAGE_kmod-usb-serial-option=y
CONFIG_PACKAGE_kmod-usb-serial-wwan=y
CONFIG_PACKAGE_kmod-usb-net-cdc-mbim=y
CONFIG_PACKAGE_kmod-usb-net-cdc-ncm=y
CONFIG_PACKAGE_kmod-mhi-bus=y
CONFIG_PACKAGE_kmod-pcie-mhi=y

# ==========================
# 拨号协议工具
# ==========================
CONFIG_PACKAGE_modemmanager=y
CONFIG_PACKAGE_modemmanager-rpcd=y
CONFIG_PACKAGE_luci-proto-modemmanager=y
CONFIG_PACKAGE_quectel-cm=y
CONFIG_PACKAGE_umbim=y
CONFIG_PACKAGE_uqmi=y

# ==========================
# SIMCom 模块专用（SIM8260 等）
# ==========================
CONFIG_PACKAGE_kmod-usb-serial-via=y
CONFIG_PACKAGE_kmod-usb-acm=y
CONFIG_PACKAGE_kmod-usb-storage=y
CONFIG_PACKAGE_libqmi=y
CONFIG_PACKAGE_libmbim=y

# ==========================
# Web 管理界面
# ==========================
CONFIG_PACKAGE_luci-app-modem=y
CONFIG_PACKAGE_luci-app-modemmanager=y
CONFIG_PACKAGE_luci-app-sms-tool=y
CONFIG_PACKAGE_sms-tool=y

# ==========================
# 三大厂商支持
# ==========================
CONFIG_PACKAGE_quectel-CM-5G=y
CONFIG_PACKAGE_fibocom-dial=y
CONFIG_PACKAGE_smartmobi-dial=y

# ==========================
# 实用插件
# ==========================
CONFIG_PACKAGE_luci-app-mwan3=y
CONFIG_PACKAGE_luci-app-syncdial=y
CONFIG_PACKAGE_luci-app-watchcat=y
CONFIG_PACKAGE_luci-app-statistics=y
CONFIG_PACKAGE_collectd-mod-modem=y
CONFIG_PACKAGE_zram-swap=y
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_usbutils=y
CONFIG_PACKAGE_kmod-usb3=y

CONFIG_PACKAGE_luci-app-firewall=y
CONFIG_PACKAGE_luci-app-upnp=y
CONFIG_PACKAGE_luci-app-ttyd=y
CONFIG_PACKAGE_luci-app-filetransfer=y
